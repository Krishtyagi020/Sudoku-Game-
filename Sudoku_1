#include <iostream>
#include <cmath>
using namespace std;

bool isValid(int grid[][9], int n, int i, int j, int d) {
    for (int k = 0; k < n; k++) {
        if (grid[i][k] == d || grid[k][j] == d) { // fix 1: "gird" → "grid"
            return false;
        }
    }
    int rn = sqrt(n);
    int sx = i - (i % rn);
    int sy = j - (j % rn); // fix 2: "int sy=;" → "int sy = j - (j % rn);"

    for (int x = sx; x < sx + rn; x++) { // fix 3: loop must start from sx, not 0
        for (int y = sy; y < sy + rn; y++) { // fix 4: loop must start from sy, not 0
            if (grid[x][y] == d) {
                return false;
            }
        }
    }
    return true;
}

void solveSudoku(int grid[][9], int n, int i, int j) { // fix 5: missing "int" before grid
    if (i == n) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                cout << grid[i][j] << " ";
            }
            cout << endl; // fix 6: "endll" → "endl" + added missing semicolon
        }
        cout << endl;
        return;
    }
    if (j == n) {
        solveSudoku(grid, n, i + 1, 0);
        return;
    }
    if (grid[i][j] != 0) {
        solveSudoku(grid, n, i, j + 1);
        return;
    }
    for (int d = 1; d <= 9; d++) {
        if (isValid(grid, n, i, j, d)) {
            grid[i][j] = d;
            solveSudoku(grid, n, i, j + 1);
            grid[i][j] = 0;
        }
    }
}

int main() {
    int n = 9;
    int grid[][9] = {
        {3, 0, 6, 5, 0, 8, 4, 0, 0},
        {5, 2, 0, 0, 0, 0, 0, 0, 0},
        {0, 8, 7, 0, 0, 0, 0, 3, 1},
        {0, 0, 3, 0, 1, 0, 0, 8, 0},
        {9, 0, 0, 8, 6, 3, 0, 0, 5},
        {0, 5, 0, 0, 9, 0, 6, 0, 0},
        {1, 3, 0, 0, 0, 0, 2, 5, 0},
        {0, 0, 0, 0, 0, 0, 0, 7, 4},
        {0, 0, 5, 2, 0, 6, 3, 0, 0}
    };
    solveSudoku(grid, n, 0, 0); // fix 7: missing function call in main
    return 0;
}